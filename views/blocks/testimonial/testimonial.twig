{# 
    ====================================================================
    Name:           testimonial.twig
    Type:           Block 
    Since:          0.0.1
    Description:    A testimonial block
    Available vars: id (of block), classes (of block), {fields by key}, site
    ====================================================================
#}

{# <pre>{{dump() }}</pre> #}

<div id="{{ id }}" class="block block--testimonial{{ classes }}" data-position="{{ image_position }}">

	<div class="testimonial">
		{{ content|raw }}
        <div class="testimonial__meta">
            <picture class="testimonial__image">
                <source srcset="{{ image.sizes.thumbnail }}" data-srcset="{{ image.sizes.thumbnail }}" media="(max-width: 767px)">
                <source srcset="{{ image.sizes.thumbnail }}" data-srcset="{{ image.sizes.thumbnail }}" media="(min-width: 768px) and (max-width: 959px)">
                <source srcset="{{ image.sizes.bigthumb }}" data-srcset="{{ image.sizes.bigthumb }}" media="(min-width: 960px) and (max-width: 1500px)">
                <source srcset="{{ image.sizes.url }}" data-srcset="{{ image.sizes.url }}" media="(min-width: 1500px)">
                <img class="testimonial-image" src="{{ image.url }}" data-src="{{ image.url }}" title="{{ image.title }}" alt="{{ (image.alt)? image.alt : image.title }}"/>
            </picture>
            <div class="testimonial__info">
                <span class="testimonial__name">{{ name }}</span>
                <span class="testimonial__function">{{ function }}</span>
            </div>
        </div>
	</div>

</div>
